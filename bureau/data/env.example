# Anthropic API key for bureau's persona nodes (Builder, Reviewer).
# Get yours at https://console.anthropic.com → API Keys.
# Bureau reads this from ~/.bureau/.env or from your shell environment.
# Shell environment takes precedence over the file.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Output format for bureau events emitted to stdout.
# text (default): [bureau] event  key=value
# cloudevents:    CloudEvents 1.0 NDJSON — one JSON object per line
# BUREAU_OUTPUT_FORMAT=cloudevents

# Override the CloudEvents `source` URI (cloudevents mode only).
# Defaults to urn:bureau:run:<run-id> when unset.
# BUREAU_SOURCE_URI=https://github.com/your-org/your-repo
