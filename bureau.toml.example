[models]
# Model for Planner node (high-reasoning — design and constitution check)
planner = "claude-opus-4-6"
# Model for Builder node (high-throughput — implementation volume)
builder = "claude-haiku-4-5-20251001"
# Model for Critic node (high-reasoning — adversarial review)
critic = "claude-opus-4-6"

[github]
# Name of the environment variable holding your GitHub personal access token
token_env = "GITHUB_TOKEN"

[bureau]
# Maximum number of Critic send-backs before escalating to the developer
max_retries = 3
